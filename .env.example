# ============================================
# BargAIn — Variables de Entorno
# Copiar a .env y configurar valores reales
# ============================================

# Django
DJANGO_SETTINGS_MODULE=config.settings.dev
SECRET_KEY=CHANGE-ME-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Base de datos (PostgreSQL + PostGIS)
# Usar localhost para desarrollo local sin Docker; en Docker se sobreescribe automáticamente
DATABASE_URL=postgis://bargain_user:bargain_password@localhost:5432/bargain_db

# Credenciales de PostgreSQL (usadas por docker-compose.yml de producción)
POSTGRES_USER=bargain_user
POSTGRES_PASSWORD=bargain_password
POSTGRES_DB=bargain_db

# Redis (Celery broker + cache)
REDIS_URL=redis://localhost:6379/0

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081,exp://localhost:8081

# JWT
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# Google Maps / Places API
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# OSRM (alternativa OSS a Google Directions)
OSRM_BASE_URL=https://router.project-osrm.org

# Anthropic (Asistente LLM)
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# OCR
TESSERACT_PATH=/usr/bin/tesseract

# Email (notificaciones)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# Sentry (monitorización de errores)
SENTRY_DSN=

# Scraping
SCRAPING_USER_AGENT=BargAIn-Bot/1.0 (+https://github.com/QHX0329/bargain-tfg)
SCRAPING_CONCURRENT_REQUESTS=4
SCRAPING_DOWNLOAD_DELAY=2
