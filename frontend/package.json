{
  "name": "bargain-frontend",
  "version": "1.0.0",
  "private": true,
  "main": "App.tsx",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "jest",
    "lint": "eslint src/ --ext .ts,.tsx",
    "format": "prettier --check \"src/**/*.{ts,tsx}\"",
